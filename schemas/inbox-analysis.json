{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "overview",
    "urgentThreads",
    "replyRecommendations",
    "followUps",
    "sourceRefs"
  ],
  "properties": {
    "overview": {
      "type": "string"
    },
    "urgentThreads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "threadId",
          "subject",
          "reason"
        ],
        "properties": {
          "threadId": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "replyRecommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "threadId",
          "recommendation",
          "draft"
        ],
        "properties": {
          "threadId": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          },
          "draft": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": false,
            "required": [
              "threadId",
              "to",
              "cc",
              "bcc",
              "subject",
              "bodyText"
            ],
            "properties": {
              "threadId": {
                "type": "string"
              },
              "to": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "cc": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "bcc": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "subject": {
                "type": "string"
              },
              "bodyText": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "followUps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "dueAt",
          "status",
          "sourceRefs"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "dueAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string"
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
