{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "needsClarification",
    "sourceRefs"
  ],
  "properties": {
    "needsClarification": {
      "type": "boolean"
    },
    "clarifyingQuestion": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "proposedSlots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "start",
          "end",
          "reason"
        ],
        "properties": {
          "start": {
            "type": "string"
          },
          "end": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "draftInvitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject",
        "body"
      ],
      "properties": {
        "subject": {
          "type": "string"
        },
        "body": {
          "type": "string"
        }
      }
    },
    "stagedActionId": {
      "type": "string"
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
