{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "summary",
    "keyPoints",
    "actionItems",
    "sourceRefs"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "keyPoints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actionItems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
